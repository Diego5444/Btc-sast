rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Users can only read their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Users cannot modify their balance or critical stats directly
      // Only Cloud Functions should modify these via admin SDK
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if false; 
      allow delete: if false;
    }
    
    match /withdrawals/{withdrawalId} {
      // Users can only read their own withdrawals
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      
      // Withdrawals are created via Cloud Functions for security
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}